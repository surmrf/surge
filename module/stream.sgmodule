[Panel]
stream-all = script-name=stream-all, title="流媒体解锁检测", content="请刷新面板", update-interval={{{UPDATE_INTERVAL}}}

[Script]
stream-all = type=generic, timeout=15, script-path=https://raw.githubusercontent.com/surmrf/surge/refs/heads/master/module/panel/stream-check.js
